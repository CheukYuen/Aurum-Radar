{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "信息关联分析输入 Schema",
  "description": "待分析的结构化情报事件集合，供关联分析识别跨市场、跨品类、跨时间的关联与传导关系。",
  "type": "object",
  "required": ["batch_meta", "items"],
  "properties": {
    "batch_meta": {
      "type": "object",
      "required": ["time_window"],
      "properties": {
        "market": { "type": "string", "description": "聚焦市场，跨市场分析时可为 Global。" },
        "region": { "type": "string", "description": "区域归属。" },
        "time_window": { "type": "string", "description": "ISO 区间，例如 2026-05-01/2026-05-21。" },
        "item_count": { "type": "integer" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "market", "category", "event_summary", "published_at", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "market": { "type": "string" },
          "region": { "type": "string" },
          "source_type": { "type": "string", "enum": ["news", "social", "ecommerce", "regulator", "brand_official", "report", "other"] },
          "source_name": { "type": "string" },
          "published_at": { "type": "string" },
          "category": { "type": "string", "enum": ["price", "competition", "product", "regulation", "channel", "consumer", "social", "macro"] },
          "event_summary": { "type": "string" },
          "signal_direction": { "type": "string", "enum": ["positive", "negative", "mixed", "neutral"] },
          "intensity": { "type": "integer", "minimum": 1, "maximum": 5 },
          "impact_scope": { "type": "array", "items": { "type": "string" } },
          "env_factors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "factor_id": { "type": "string" },
                "name": { "type": "string" },
                "is_primary": { "type": "boolean" }
              }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "historical_context": {
      "type": "array",
      "description": "可选：近期历史事件摘要，供时序模式匹配与传导时滞参考。",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "market": { "type": "string" },
          "category": { "type": "string" },
          "event_summary": { "type": "string" },
          "published_at": { "type": "string" }
        }
      }
    }
  }
}
