{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "信息关联分析输出 Schema",
  "description": "关联分析结果：包含关联边、因果链、时序模式、隐性依赖等，每条判断均绑定证据。",
  "type": "object",
  "required": [
    "correlation_summary",
    "correlation_edges",
    "causal_chains",
    "temporal_patterns",
    "hidden_dependencies",
    "evidence_chain",
    "expert_disagreements",
    "confidence",
    "next_observation_points"
  ],
  "properties": {
    "correlation_summary": { "type": "string", "description": "整体关联结论（3-5 句）。" },
    "market": { "type": "string" },
    "time_window": { "type": "string" },
    "correlation_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "target_id", "correlation_type", "strength", "evidence_ids", "confidence"],
        "properties": {
          "source_id": { "type": "string" },
          "target_id": { "type": "string" },
          "correlation_type": { "type": "string", "enum": ["causal", "reinforcing", "contradicting", "co_occurrence", "lead_lag"] },
          "strength": { "type": "string", "enum": ["strong", "moderate", "weak"] },
          "description": { "type": "string" },
          "time_lag_days": { "type": "integer" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "causal_chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chain_id", "nodes", "description", "evidence_ids", "confidence"],
        "properties": {
          "chain_id": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["event_id", "role"],
              "properties": {
                "event_id": { "type": "string" },
                "role": { "type": "string", "enum": ["trigger", "amplifier", "mediator", "outcome"] },
                "mechanism": { "type": "string" }
              }
            }
          },
          "description": { "type": "string" },
          "total_lag_days": { "type": "integer" },
          "alternative_explanation": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "temporal_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern_type", "description", "evidence_ids", "confidence"],
        "properties": {
          "pattern_type": { "type": "string", "enum": ["cyclical", "trend_acceleration", "trend_reversal", "lead_lag_pair", "simultaneous_shift"] },
          "description": { "type": "string" },
          "historical_precedent": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "hidden_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["factor", "events", "description", "evidence_ids", "confidence"],
        "properties": {
          "factor": { "type": "string" },
          "events": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "evidence_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "used_in", "source_reliability"],
        "properties": {
          "evidence_id": { "type": "string" },
          "used_in": { "type": "array", "items": { "type": "string" } },
          "source_reliability": { "type": "string", "enum": ["primary", "secondary", "unverified"] }
        }
      }
    },
    "expert_disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "positions", "resolution"],
        "properties": {
          "topic": { "type": "string" },
          "positions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "expert": { "type": "string" },
                "view": { "type": "string" }
              }
            }
          },
          "resolution": { "type": "string" }
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": ["level", "score", "rationale"],
      "properties": {
        "level": { "type": "string", "enum": ["high", "medium", "low"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string" }
      }
    },
    "next_observation_points": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
